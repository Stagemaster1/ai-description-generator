# SolTecSol AI Description Generator Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI Configuration (REQUIRED)
OPENAI_API_KEY=your_openai_api_key_here

# PayPal Configuration (REQUIRED)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox
PAYPAL_STARTER_PLAN_ID=P-your_starter_plan_id_here
PAYPAL_PROFESSIONAL_PLAN_ID=P-your_professional_plan_id_here
PAYPAL_ENTERPRISE_PLAN_ID=P-your_enterprise_plan_id_here

# Barcode Lookup Configuration (OPTIONAL)
BARCODE_LOOKUP_API_KEY=your_barcode_lookup_api_key_here

# Application Configuration (REQUIRED)
URL=https://your-site-domain.com

# Additional Configuration
NODE_ENV=production